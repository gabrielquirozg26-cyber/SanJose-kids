{
  "unidad1": {
    "titulo": "Semillas de Fe",
    "oraciones": [
      {
        "id": "u1_padre_nuestro",
        "nombre": "Padre Nuestro",
        "icono": "🙏",
        "versos": [
          { "id": "pn_01", "texto": "Padre nuestro que estás en el cielo", "palabraFaltante": "cielo", "opcionesSeleccion": ["cielo", "mundo", "mar", "tiempo"], "palabrasOrdenar": ["Padre", "nuestro", "que", "estás", "en", "el", "cielo"] },
          { "id": "pn_02", "texto": "santificado sea tu nombre", "palabraFaltante": "santificado", "opcionesSeleccion": ["santificado", "bendito", "glorioso", "honrado"], "palabrasOrdenar": ["santificado", "sea", "tu", "nombre"] },
          { "id": "pn_03", "texto": "venga a nosotros tu reino", "palabraFaltante": "reino", "opcionesSeleccion": ["reino", "gracia", "gloria", "poder"], "palabrasOrdenar": ["venga", "a", "nosotros", "tu", "reino"] },
          { "id": "pn_04", "texto": "hágase tu voluntad en la tierra como en el cielo", "palabraFaltante": "voluntad", "opcionesSeleccion": ["voluntad", "nombre", "paz", "obra"], "palabrasOrdenar": ["hágase", "tu", "voluntad", "en", "la", "tierra", "como", "en", "el", "cielo"] },
          { "id": "pn_05", "texto": "danos hoy nuestro pan de cada día", "palabraFaltante": "pan", "opcionesSeleccion": ["pan", "don", "bien", "fruto"], "palabrasOrdenar": ["danos", "hoy", "nuestro", "pan", "de", "cada", "día"] },
          { "id": "pn_06", "texto": "perdona nuestras ofensas como nosotros perdonamos a los que nos ofenden", "palabraFaltante": "ofensas", "opcionesSeleccion": ["ofensas", "deudas", "faltas", "pecados"], "palabrasOrdenar": ["perdona", "nuestras", "ofensas", "como", "nosotros", "perdonamos", "a", "los", "que", "nos", "ofenden"] },
          { "id": "pn_07", "texto": "no nos dejes caer en la tentación", "palabraFaltante": "tentación", "opcionesSeleccion": ["tentación", "oscuridad", "tristeza", "duda"], "palabrasOrdenar": ["no", "nos", "dejes", "caer", "en", "la", "tentación"] },
          { "id": "pn_08", "texto": "y líbranos del mal", "palabraFaltante": "mal", "opcionesSeleccion": ["mal", "dolor", "miedo", "pecado"], "palabrasOrdenar": ["y", "líbranos", "del", "mal"] }
        ]
      },
      {
        "id": "u1_ave_maria",
        "nombre": "Ave María",
        "icono": "🌹",
        "versos": [
          { "id": "am_01", "texto": "Dios te salve María llena eres de gracia", "palabraFaltante": "gracia", "opcionesSeleccion": ["gracia", "gloria", "luz", "amor"], "palabrasOrdenar": ["Dios", "te", "salve", "María", "llena", "eres", "de", "gracia"] },
          { "id": "am_02", "texto": "el Señor es contigo", "palabraFaltante": "contigo", "opcionesSeleccion": ["contigo", "en ti", "junto a ti", "con tigo"], "palabrasOrdenar": ["el", "Señor", "es", "contigo"] },
          { "id": "am_03", "texto": "bendita tú eres entre todas las mujeres", "palabraFaltante": "mujeres", "opcionesSeleccion": ["mujeres", "almas", "personas", "criaturas"], "palabrasOrdenar": ["bendita", "tú", "eres", "entre", "todas", "las", "mujeres"] },
          { "id": "am_04", "texto": "y bendito es el fruto de tu vientre Jesús", "palabraFaltante": "vientre", "opcionesSeleccion": ["vientre", "amor", "gracia", "ser"], "palabrasOrdenar": ["y", "bendito", "es", "el", "fruto", "de", "tu", "vientre", "Jesús"] },
          { "id": "am_05", "texto": "Santa María Madre de Dios", "palabraFaltante": "Madre", "opcionesSeleccion": ["Madre", "Reina", "Virgen", "Sierva"], "palabrasOrdenar": ["Santa", "María", "Madre", "de", "Dios"] },
          { "id": "am_06", "texto": "ruega por nosotros los pecadores", "palabraFaltante": "pecadores", "opcionesSeleccion": ["pecadores", "fieles", "hijos", "creyentes"], "palabrasOrdenar": ["ruega", "por", "nosotros", "los", "pecadores"] },
          { "id": "am_07", "texto": "ahora y en la hora de nuestra muerte amén", "palabraFaltante": "muerte", "opcionesSeleccion": ["muerte", "vida", "hora", "partida"], "palabrasOrdenar": ["ahora", "y", "en", "la", "hora", "de", "nuestra", "muerte", "amén"] }
        ]
      },
      {
        "id": "u1_gloria",
        "nombre": "Gloria",
        "icono": "✨",
        "versos": [
          { "id": "gl_01", "texto": "Gloria al Padre y al Hijo y al Espíritu Santo", "palabraFaltante": "Espíritu", "opcionesSeleccion": ["Espíritu", "Señor", "Dios", "Ángel"], "palabrasOrdenar": ["Gloria", "al", "Padre", "y", "al", "Hijo", "y", "al", "Espíritu", "Santo"] },
          { "id": "gl_02", "texto": "como era en el principio ahora y siempre", "palabraFaltante": "principio", "opcionesSeleccion": ["principio", "inicio", "origen", "comienzo"], "palabrasOrdenar": ["como", "era", "en", "el", "principio", "ahora", "y", "siempre"] },
          { "id": "gl_03", "texto": "y por los siglos de los siglos amén", "palabraFaltante": "siglos", "opcionesSeleccion": ["siglos", "tiempos", "años", "días"], "palabrasOrdenar": ["y", "por", "los", "siglos", "de", "los", "siglos", "amén"] }
        ]
      },
      {
        "id": "u1_angel_guarda",
        "nombre": "Ángel de la Guarda",
        "icono": "👼",
        "versos": [
          { "id": "ag_01", "texto": "Ángel de Dios que eres mi custodio", "palabraFaltante": "custodio", "opcionesSeleccion": ["custodio", "amigo", "guía", "pastor"], "palabrasOrdenar": ["Ángel", "de", "Dios", "que", "eres", "mi", "custodio"] },
          { "id": "ag_02", "texto": "pues la bondad divina me ha encomendado a ti", "palabraFaltante": "encomendado", "opcionesSeleccion": ["encomendado", "enviado", "confiado", "entregado"], "palabrasOrdenar": ["pues", "la", "bondad", "divina", "me", "ha", "encomendado", "a", "ti"] },
          { "id": "ag_03", "texto": "ilumíname guárdame y gobiérname", "palabraFaltante": "ilumíname", "opcionesSeleccion": ["ilumíname", "ayúdame", "cuídame", "sálvame"], "palabrasOrdenar": ["ilumíname", "guárdame", "y", "gobiérname"] },
          { "id": "ag_04", "texto": "en este día amén", "palabraFaltante": "día", "opcionesSeleccion": ["día", "tiempo", "momento", "instante"], "palabrasOrdenar": ["en", "este", "día", "amén"] }
        ]
      }
    ]
  },
  "unidad2": {
    "titulo": "Corazón Limpio",
    "oraciones": [
      {
        "id": "u2_yo_confieso",
        "nombre": "Yo Confieso",
        "icono": "😔",
        "versos": [
          { "id": "yc_01", "texto": "Yo confieso ante Dios todopoderoso", "palabraFaltante": "todopoderoso", "opcionesSeleccion": ["todopoderoso", "misericordioso", "eterno", "santo"], "palabrasOrdenar": ["Yo", "confieso", "ante", "Dios", "todopoderoso"] },
          { "id": "yc_02", "texto": "y ante vosotros hermanos", "palabraFaltante": "hermanos", "opcionesSeleccion": ["hermanos", "santos", "fieles", "amigos"], "palabrasOrdenar": ["y", "ante", "vosotros", "hermanos"] },
          { "id": "yc_03", "texto": "que he pecado mucho de pensamiento palabra obra y omisión", "palabraFaltante": "omisión", "opcionesSeleccion": ["omisión", "acción", "intención", "corazón"], "palabrasOrdenar": ["que", "he", "pecado", "mucho", "de", "pensamiento", "palabra", "obra", "y", "omisión"] },
          { "id": "yc_04", "texto": "por mi culpa por mi culpa por mi grandísima culpa", "palabraFaltante": "grandísima", "opcionesSeleccion": ["grandísima", "grande", "enorme", "terrible"], "palabrasOrdenar": ["por", "mi", "culpa", "por", "mi", "culpa", "por", "mi", "grandísima", "culpa"] },
          { "id": "yc_05", "texto": "por eso ruego a Santa María siempre Virgen", "palabraFaltante": "Virgen", "opcionesSeleccion": ["Virgen", "Madre", "Reina", "Santa"], "palabrasOrdenar": ["por", "eso", "ruego", "a", "Santa", "María", "siempre", "Virgen"] },
          { "id": "yc_06", "texto": "a los ángeles a los santos y a vosotros hermanos", "palabraFaltante": "ángeles", "opcionesSeleccion": ["ángeles", "santos", "apóstoles", "profetas"], "palabrasOrdenar": ["a", "los", "ángeles", "a", "los", "santos", "y", "a", "vosotros", "hermanos"] },
          { "id": "yc_07", "texto": "que rueguen por mí a Dios nuestro Señor", "palabraFaltante": "rueguen", "opcionesSeleccion": ["rueguen", "pidan", "oren", "intercedan"], "palabrasOrdenar": ["que", "rueguen", "por", "mí", "a", "Dios", "nuestro", "Señor"] }
        ]
      },
      {
        "id": "u2_acto_contricion",
        "nombre": "Acto de Contrición",
        "icono": "🕊️",
        "versos": [
          { "id": "ac_01", "texto": "Señor mío Jesucristo Dios y hombre verdadero", "palabraFaltante": "verdadero", "opcionesSeleccion": ["verdadero", "eterno", "bendito", "santo"], "palabrasOrdenar": ["Señor", "mío", "Jesucristo", "Dios", "y", "hombre", "verdadero"] },
          { "id": "ac_02", "texto": "me pesa de todo corazón haberte ofendido", "palabraFaltante": "corazón", "opcionesSeleccion": ["corazón", "alma", "ser", "espíritu"], "palabrasOrdenar": ["me", "pesa", "de", "todo", "corazón", "haberte", "ofendido"] },
          { "id": "ac_03", "texto": "propongo firmemente con tu gracia enmendarme", "palabraFaltante": "enmendarme", "opcionesSeleccion": ["enmendarme", "mejorarme", "convertirme", "cambiarme"], "palabrasOrdenar": ["propongo", "firmemente", "con", "tu", "gracia", "enmendarme"] },
          { "id": "ac_04", "texto": "y no pecar más y alejarme de las ocasiones de pecado", "palabraFaltante": "alejarme", "opcionesSeleccion": ["alejarme", "apartarme", "librarme", "huir"], "palabrasOrdenar": ["y", "no", "pecar", "más", "y", "alejarme", "de", "las", "ocasiones", "de", "pecado"] }
        ]
      },
      {
        "id": "u2_dulce_madre",
        "nombre": "Dulce Madre",
        "icono": "💙",
        "versos": [
          { "id": "dm_01", "texto": "Dulce Madre no te alejes", "palabraFaltante": "alejes", "opcionesSeleccion": ["alejes", "apartes", "olvides", "vayas"], "palabrasOrdenar": ["Dulce", "Madre", "no", "te", "alejes"] },
          { "id": "dm_02", "texto": "tu vista de mi no apartes", "palabraFaltante": "apartes", "opcionesSeleccion": ["vuelvas", "apartes", "alejes", "quites"], "palabrasOrdenar": ["tu", "vista", "de", "mi", "no", "apartes"] },
          { "id": "dm_03", "texto": "ven conmigo a todas partes", "palabraFaltante": "partes", "opcionesSeleccion": ["partes", "horas", "noches", "cruces"], "palabrasOrdenar": ["ven", "conmigo", "a", "todas", "partes"] },
          { "id": "dm_04", "texto": "y solo nunca me dejes", "palabraFaltante": "nunca", "opcionesSeleccion": ["no", "jamas", "siempre", "nunca"], "palabrasOrdenar": ["y", "solo", "nunca", "me", "dejes"] }
        ]
      }
    ]
  },
  "unidad3": {
    "titulo": "La Roca de la Iglesia",
    "oraciones": [
      {
        "id": "u3_credo_apostolico",
        "nombre": "Credo Apostólico",
        "icono": "⛪",
        "versos": [
          { "id": "ca_01", "texto": "Creo en Dios Padre todopoderoso creador del cielo y de la tierra", "palabraFaltante": "creador", "opcionesSeleccion": ["creador", "señor", "padre", "rey"], "palabrasOrdenar": ["Creo", "en", "Dios", "Padre", "todopoderoso", "creador", "del", "cielo", "y", "de", "la", "tierra"] },
          { "id": "ca_02", "texto": "y en Jesucristo su único Hijo nuestro Señor", "palabraFaltante": "único", "opcionesSeleccion": ["único", "amado", "eterno", "santo"], "palabrasOrdenar": ["y", "en", "Jesucristo", "su", "único", "Hijo", "nuestro", "Señor"] },
          { "id": "ca_03", "texto": "que fue concebido por obra y gracia del Espíritu Santo", "palabraFaltante": "concebido", "opcionesSeleccion": ["concebido", "formado", "nacido", "enviado"], "palabrasOrdenar": ["que", "fue", "concebido", "por", "obra", "y", "gracia", "del", "Espíritu", "Santo"] },
          { "id": "ca_04", "texto": "nació de Santa María Virgen", "palabraFaltante": "Virgen", "opcionesSeleccion": ["Virgen", "Santa", "Madre", "pura"], "palabrasOrdenar": ["nació", "de", "Santa", "María", "Virgen"] },
          { "id": "ca_05", "texto": "padeció bajo el poder de Poncio Pilato", "palabraFaltante": "Poncio", "opcionesSeleccion": ["Poncio", "Herodes", "César", "Barrabás"], "palabrasOrdenar": ["padeció", "bajo", "el", "poder", "de", "Poncio", "Pilato"] },
          { "id": "ca_06", "texto": "fue crucificado muerto y sepultado", "palabraFaltante": "sepultado", "opcionesSeleccion": ["sepultado", "enterrado", "guardado", "puesto"], "palabrasOrdenar": ["fue", "crucificado", "muerto", "y", "sepultado"] },
          { "id": "ca_07", "texto": "al tercer día resucitó de entre los muertos", "palabraFaltante": "resucitó", "opcionesSeleccion": ["resucitó", "volvió", "nació", "partió"], "palabrasOrdenar": ["al", "tercer", "día", "resucitó", "de", "entre", "los", "muertos"] },
          { "id": "ca_08", "texto": "subió a los cielos y está sentado a la derecha de Dios Padre todopoderoso", "palabraFaltante": "derecha", "opcionesSeleccion": ["derecha", "gloria", "diestra", "altura"], "palabrasOrdenar": ["subió", "a", "los", "cielos", "y", "está", "sentado", "a", "la", "derecha", "de", "Dios", "Padre", "todopoderoso"] },
          { "id": "ca_09", "texto": "creo en el Espíritu Santo la santa Iglesia Católica", "palabraFaltante": "Católica", "opcionesSeleccion": ["Católica", "Apostólica", "Universal", "Romana"], "palabrasOrdenar": ["creo", "en", "el", "Espíritu", "Santo", "la", "santa", "Iglesia", "Católica"] },
          { "id": "ca_10", "texto": "la comunión de los santos el perdón de los pecados", "palabraFaltante": "comunión", "opcionesSeleccion": ["comunión", "unión", "gracia", "fuerza"], "palabrasOrdenar": ["la", "comunión", "de", "los", "santos", "el", "perdón", "de", "los", "pecados"] },
          { "id": "ca_11", "texto": "la resurrección de la carne y la vida eterna amén", "palabraFaltante": "resurrección", "opcionesSeleccion": ["resurrección", "ascensión", "glorificación", "elevación"], "palabrasOrdenar": ["la", "resurrección", "de", "la", "carne", "y", "la", "vida", "eterna", "amén"] }
        ]
      },
      {
        "id": "u3_salve",
        "nombre": "La Salve",
        "icono": "🌊",
        "versos": [
          { "id": "sv_01", "texto": "Dios te salve Reina y Madre de misericordia", "palabraFaltante": "misericordia", "opcionesSeleccion": ["misericordia", "compasión", "amor", "gracia"], "palabrasOrdenar": ["Dios", "te", "salve", "Reina", "y", "Madre", "de", "misericordia"] },
          { "id": "sv_02", "texto": "vida dulzura y esperanza nuestra", "palabraFaltante": "dulzura", "opcionesSeleccion": ["dulzura", "guía", "luz", "fuerza"], "palabrasOrdenar": ["vida", "dulzura", "y", "esperanza", "nuestra"] },
          { "id": "sv_03", "texto": "a ti clamamos los desterrados hijos de Eva", "palabraFaltante": "desterrados", "opcionesSeleccion": ["desterrados", "pecadores", "humildes", "pobres"], "palabrasOrdenar": ["a", "ti", "clamamos", "los", "desterrados", "hijos", "de", "Eva"] },
          { "id": "sv_04", "texto": "a ti suspiramos gimiendo y llorando en este valle de lágrimas", "palabraFaltante": "lágrimas", "opcionesSeleccion": ["lágrimas", "penas", "sombras", "tristezas"], "palabrasOrdenar": ["a", "ti", "suspiramos", "gimiendo", "y", "llorando", "en", "este", "valle", "de", "lágrimas"] },
          { "id": "sv_05", "texto": "ea pues señora abogada nuestra vuelve a nosotros esos tus ojos misericordiosos", "palabraFaltante": "abogada", "opcionesSeleccion": ["abogada", "mediadora", "intercesora", "protectora"], "palabrasOrdenar": ["ea", "pues", "señora", "abogada", "nuestra", "vuelve", "a", "nosotros", "esos", "tus", "ojos", "misericordiosos"] },
          { "id": "sv_06", "texto": "y después de este destierro muéstranos a Jesús fruto bendito de tu vientre", "palabraFaltante": "destierro", "opcionesSeleccion": ["destierro", "camino", "exilio", "viaje"], "palabrasOrdenar": ["y", "después", "de", "este", "destierro", "muéstranos", "a", "Jesús", "fruto", "bendito", "de", "tu", "vientre"] }
        ]
      }
    ]
  },
  "unidad4": {
    "titulo": "Camino de Vida",
    "oraciones": [
      {
        "id": "u4_mandamientos",
        "nombre": "10 Mandamientos",
        "icono": "📜",
        "versos": [
          { "id": "mn_01", "texto": "Amarás a Dios sobre todas las cosas", "palabraFaltante": "Amarás", "opcionesSeleccion": ["Amarás", "Honrarás", "Servirás", "Adorarás"], "palabrasOrdenar": ["Amarás", "a", "Dios", "sobre", "todas", "las", "cosas"] },
          { "id": "mn_02", "texto": "no tomarás el nombre de Dios en vano", "palabraFaltante": "vano", "opcionesSeleccion": ["vano", "mentira", "burla", "ofensa"], "palabrasOrdenar": ["no", "tomarás", "el", "nombre", "de", "Dios", "en", "vano"] },
          { "id": "mn_03", "texto": "santificarás las fiestas", "palabraFaltante": "santificarás", "opcionesSeleccion": ["santificarás", "guardarás", "celebrarás", "honrarás"], "palabrasOrdenar": ["santificarás", "las", "fiestas"] },
          { "id": "mn_04", "texto": "honrarás a tu padre y a tu madre", "palabraFaltante": "honrarás", "opcionesSeleccion": ["honrarás", "amarás", "obedecerás", "respetarás"], "palabrasOrdenar": ["honrarás", "a", "tu", "padre", "y", "a", "tu", "madre"] },
          { "id": "mn_05", "texto": "no matarás", "palabraFaltante": "matarás", "opcionesSeleccion": ["matarás", "robarás", "mentirás", "pecarás"], "palabrasOrdenar": ["no", "matarás"] },
          { "id": "mn_06", "texto": "no cometerás actos impuros", "palabraFaltante": "impuros", "opcionesSeleccion": ["impuros", "malos", "injustos", "graves"], "palabrasOrdenar": ["no", "cometerás", "actos", "impuros"] },
          { "id": "mn_07", "texto": "no robarás", "palabraFaltante": "robarás", "opcionesSeleccion": ["robarás", "mentirás", "pecarás", "engañarás"], "palabrasOrdenar": ["no", "robarás"] },
          { "id": "mn_08", "texto": "no darás falso testimonio ni mentirás", "palabraFaltante": "testimonio", "opcionesSeleccion": ["testimonio", "juicio", "juramento", "consejo"], "palabrasOrdenar": ["no", "darás", "falso", "testimonio", "ni", "mentirás"] },
          { "id": "mn_09", "texto": "no consentirás pensamientos ni deseos impuros", "palabraFaltante": "consentirás", "opcionesSeleccion": ["consentirás", "tendrás", "guardarás", "alimentarás"], "palabrasOrdenar": ["no", "consentirás", "pensamientos", "ni", "deseos", "impuros"] },
          { "id": "mn_10", "texto": "no codiciarás los bienes ajenos", "palabraFaltante": "codiciarás", "opcionesSeleccion": ["codiciarás", "robarás", "desearás", "envidiarás"], "palabrasOrdenar": ["no", "codiciarás", "los", "bienes", "ajenos"] }
        ]
      },
      {
        "id": "u4_bienaventuranzas",
        "nombre": "Bienaventuranzas",
        "icono": "🕊️",
        "versos": [
          { "id": "bv_01", "texto": "bienaventurados los pobres de espíritu porque de ellos es el reino de los cielos", "palabraFaltante": "espíritu", "opcionesSeleccion": ["espíritu", "corazón", "alma", "fe"], "palabrasOrdenar": ["bienaventurados", "los", "pobres", "de", "espíritu", "porque", "de", "ellos", "es", "el", "reino", "de", "los", "cielos"] },
          { "id": "bv_02", "texto": "bienaventurados los que lloran porque ellos serán consolados", "palabraFaltante": "consolados", "opcionesSeleccion": ["consolados", "bendecidos", "salvados", "premiados"], "palabrasOrdenar": ["bienaventurados", "los", "que", "lloran", "porque", "ellos", "serán", "consolados"] },
